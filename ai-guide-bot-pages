let level = 'beginner';
let loading = false;
const messagesEl = document.getElementById('messages');

function setLevel(lv) {
  level = lv;
  document.getElementById('btn-beginner').className = 'lv-btn' + (lv === 'beginner' ? ' active-beginner' : '');
  document.getElementById('btn-advanced').className = 'lv-btn' + (lv === 'advanced' ? ' active-advanced' : '');
  const label = lv === 'beginner'
    ? '🌱 입문자 모드로 바꿨어요 — 쉽고 친절하게 안내해드릴게요!'
    : '⚡ 실무자 모드로 바꿨어요 — 어떤 기능이 궁금한지 골라서 물어보세요!';
  addBotMessage(label, lv);
}

function addBotMessage(text, lv, features) {
  const div = document.createElement('div');
  div.className = 'msg bot';
  const html = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');
  const badge = lv === 'beginner'
    ? '<span class="lv-badge b">🌱 입문자 모드</span><br>'
    : lv === 'advanced'
    ? '<span class="lv-badge a">⚡ 실무자 모드</span><br>'
    : '';
  let featHtml = '';
  if (features && features.length) {
    featHtml = '<div class="feat-btns">' +
      features.map(f => `<button class="feat-btn" onclick="sendChip('${f.prompt}', true)">${f.label}</button>`).join('') +
      '</div>';
  }
  div.innerHTML = `<div class="msg-av">AI</div><div class="msg-bubble">${badge}${html}${featHtml}</div>`;
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function addMessage(role, text) {
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  div.innerHTML = `<div class="msg-bubble">${text.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}</div>`;
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function showTyping() {
  const div = document.createElement('div');
  div.className = 'msg bot'; div.id = 'typing';
  div.innerHTML = `<div class="msg-av">AI</div><div class="msg-bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function removeTyping() {
  const el = document.getElementById('typing');
  if (el) el.remove();
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 80) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

let fromFeatureBtn = false;

function sendChip(text, isFeature) {
  fromFeatureBtn = !!isFeature;
  document.getElementById('user-input').value = text;
  sendMessage();
}

function findAiFeatures(text) {
  const lower = text.toLowerCase();
  for (const key of Object.keys(AI_FEATURES)) {
    if (lower.includes(key)) return AI_FEATURES[key];
  }
  return null;
}

function isSimpleAiQuery(text) {
  const lower = text.toLowerCase();
  const simplePatterns = ['알려줘', '뭐야', '뭐에요', '소개해줘', '설명해줘'];
  const hasSimple = simplePatterns.some(p => lower.includes(p));
  const hasFeatureKeyword = ['기능', '방법', '활용', '사용법', '어떻게', '프로젝트', '아티팩트', '빌더', '연동'].some(p => lower.includes(p));
  return hasSimple && !hasFeatureKeyword;
}

async function sendMessage() {
  if (loading) return;
  const input = document.getElementById('user-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = ''; input.style.height = 'auto';
  addMessage('user', text);

  if (level === 'advanced' && !fromFeatureBtn) {
    const aiData = findAiFeatures(text);
    if (aiData && isSimpleAiQuery(text)) {
      addBotMessage(
        `**${aiData.name}**의 어떤 기능이 궁금하세요?\n아래에서 골라주세요 👇`,
        'advanced',
        aiData.features
      );
      fromFeatureBtn = false;
      return;
    }
  }
  fromFeatureBtn = false;

  loading = true;
  document.getElementById('send-btn').disabled = true;
  showTyping();
  const system = level === 'beginner' ? SYSTEM_BEGINNER : SYSTEM_ADVANCED;
  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_KEY}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          system_instruction: { parts: [{ text: system }] },
          contents: [{ role: 'user', parts: [{ text: text }] }],
          generationConfig: { maxOutputTokens: 1000, temperature: 0.7 }
        })
      }
    );
    const data = await res.json();
    removeTyping();
    if (data.error) {
      addBotMessage('오류: ' + data.error.message);
    } else {
      const reply = data.candidates?.[0]?.content?.parts?.[0]?.text || '응답을 가져오지 못했어요.';
      addBotMessage(reply, level);
    }
  } catch (e) {
    removeTyping();
    addBotMessage('오류가 발생했어요. 잠시 후 다시 시도해주세요.');
  }
  loading = false;
  document.getElementById('send-btn').disabled = false;
}

addBotMessage('안녕하세요! 저는 AI 도구 가이드봇입니다 👋\n\n위에서 본인 수준을 먼저 선택해주세요:\n\n🌱 **AI 처음이에요** — 쉬운 말로 차근차근 설명\n⚡ **어느 정도 알아요** — 기능별로 골라서 깊게 설명\n\n그다음 궁금한 AI를 물어보거나, 업무를 말하면 맞는 도구를 추천해드려요!');
</script>
