<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #ffffff; --bg2: #f5f5f3; --bg3: #eeede8;
    --text: #1a1a18; --text2: #6b6b67; --text3: #a0a09b;
    --border: rgba(0,0,0,0.1); --border2: rgba(0,0,0,0.18);
    --purple-bg: #EEEDFE; --purple-mid: #7F77DD; --purple-dark: #3C3489;
    --teal: #1D9E75; --radius: 12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a; --bg2: #252522; --bg3: #2e2e2b;
      --text: #f0efe8; --text2: #a0a09b; --text3: #6b6b67;
      --border: rgba(255,255,255,0.1); --border2: rgba(255,255,255,0.18);
      --purple-bg: #26215C; --purple-dark: #AFA9EC;
    }
  }
  body { font-family: -apple-system, BlinkMacSystemFont, "Noto Sans KR", sans-serif; background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; }
  #header { padding: 14px 20px; border-bottom: 0.5px solid var(--border); display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--purple-bg); display: flex; align-items: center; justify-content: center; font-size: 13px; color: var(--purple-dark); font-weight: 600; flex-shrink: 0; }
  .header-text h1 { font-size: 15px; font-weight: 600; color: var(--text); }
  .header-text p { font-size: 12px; color: var(--text2); margin-top: 1px; }
  .status { margin-left: auto; display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text2); }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); }
  #level-bar { padding: 10px 20px; border-bottom: 0.5px solid var(--border); display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  #level-bar span { font-size: 12px; color: var(--text2); }
  .lv-btn { padding: 5px 14px; border-radius: 20px; border: 0.5px solid var(--border2); font-size: 12px; font-family: inherit; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
  .lv-btn.active-beginner { background: #E1F5EE; color: #0F6E56; border-color: #1D9E75; font-weight: 600; }
  .lv-btn.active-advanced { background: var(--purple-bg); color: var(--purple-dark); border-color: var(--purple-mid); font-weight: 600; }
  #messages { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 16px; }
  .msg { display: flex; gap: 10px; max-width: 88%; animation: fadeUp 0.2s ease; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)} }
  .msg.user { align-self: flex-end; flex-direction: row-reverse; }
  .msg-bubble { padding: 11px 15px; border-radius: 18px; font-size: 14px; line-height: 1.65; }
  .msg.bot .msg-bubble { background: var(--bg2); color: var(--text); border-bottom-left-radius: 4px; border: 0.5px solid var(--border); }
  .msg.user .msg-bubble { background: var(--purple-dark); color: #f0efff; border-bottom-right-radius: 4px; }
  .msg-av { width: 28px; height: 28px; border-radius: 50%; background: var(--purple-bg); display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--purple-dark); font-weight: 600; flex-shrink: 0; margin-top: 2px; }
  .msg-bubble strong { font-weight: 600; }
  .msg-bubble a { color: var(--purple-mid); text-decoration: underline; }
  .feat-btns { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 10px; }
  .feat-btn { padding: 6px 13px; border: 0.5px solid var(--border2); border-radius: 20px; font-size: 12px; color: var(--text2); cursor: pointer; background: var(--bg); font-family: inherit; transition: all 0.15s; }
  .feat-btn:hover { background: var(--purple-bg); color: var(--purple-dark); border-color: var(--purple-mid); }
  #chips-wrap { padding: 0 20px 12px; flex-shrink: 0; }
  .chips-label { font-size: 11px; color: var(--text3); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px; }
  .chips { display: flex; flex-wrap: wrap; gap: 7px; }
  .chip { padding: 6px 13px; border: 0.5px solid var(--border2); border-radius: 20px; font-size: 12px; color: var(--text2); cursor: pointer; background: var(--bg); font-family: inherit; transition: all 0.15s; }
  .chip:hover { background: var(--purple-bg); color: var(--purple-dark); border-color: var(--purple-mid); }
  .chip-task { background: var(--bg2); }
  .chip-task:hover { background: #E1F5EE; color: #0F6E56; border-color: #1D9E75; }
  #input-area { padding: 12px 16px; border-top: 0.5px solid var(--border); display: flex; gap: 8px; align-items: flex-end; flex-shrink: 0; }
  #user-input { flex: 1; padding: 9px 15px; border: 0.5px solid var(--border2); border-radius: 20px; font-size: 14px; font-family: inherit; resize: none; background: var(--bg); color: var(--text); outline: none; max-height: 80px; line-height: 1.5; }
  #user-input:focus { border-color: var(--purple-mid); }
  #user-input::placeholder { color: var(--text3); }
  #send-btn { width: 38px; height: 38px; border-radius: 50%; background: var(--purple-dark); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: opacity 0.15s; }
  #send-btn:hover { opacity: 0.85; }
  #send-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  #send-btn svg { width: 15px; height: 15px; fill: white; }
  .typing { display: flex; gap: 4px; padding: 4px 2px; align-items: center; }
  .typing span { width: 7px; height: 7px; border-radius: 50%; background: var(--text3); animation: blink 1.2s infinite; }
  .typing span:nth-child(2){animation-delay:.2s}
  .typing span:nth-child(3){animation-delay:.4s}
  @keyframes blink{0%,80%,100%{opacity:.25}40%{opacity:1}}
  .lv-badge { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; margin-bottom: 6px; }
  .lv-badge.b { background: #E1F5EE; color: #0F6E56; }
  .lv-badge.a { background: var(--purple-bg); color: var(--purple-dark); }
</style>
